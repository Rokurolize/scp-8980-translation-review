{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "scp-8980-review-segment",
  "type": "object",
  "required": [
    "segment_id",
    "title",
    "source_en_path",
    "source_jp_path",
    "source_range",
    "usage_notes",
    "overview",
    "issues",
    "extra_sections",
    "conclusions"
  ],
  "properties": {
    "segment_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "source_en_path": {
      "type": "string",
      "minLength": 1
    },
    "source_jp_path": {
      "type": "string",
      "minLength": 1
    },
    "source_range": {
      "type": "object",
      "required": [
        "start",
        "end"
      ],
      "properties": {
        "start": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "end": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "note": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "usage_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "overview": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/issue"
      }
    },
    "extra_sections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/section"
      }
    },
    "conclusions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false,
    "$defs": {
    "source_ref": {
      "type": "object",
      "oneOf": [
        {
          "required": [
            "kind",
            "line"
          ],
          "properties": {
            "kind": {
              "const": "line"
            },
            "line": {
              "type": "integer",
              "minimum": 1
            }
          },
          "additionalProperties": false
        },
        {
          "required": [
            "kind",
            "note"
          ],
          "properties": {
            "kind": {
              "const": "note"
            },
            "note": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "evidence": {
      "type": "object",
      "required": [
        "en_quote",
        "jp_quote",
        "source_ref"
      ],
      "properties": {
        "en_quote": {
          "type": "string"
        },
        "jp_quote": {
          "type": "string"
        },
        "source_ref": {
          "$ref": "#/$defs/source_ref"
        }
      },
      "additionalProperties": false
    },
    "extra_block": {
      "type": "object",
      "required": [
        "label",
        "kind"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": [
            "text",
            "list"
          ]
        },
        "value": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "issue": {
      "type": "object",
        "required": [
          "id",
          "severity",
          "order",
          "heading",
          "summary",
          "why_bad",
          "fix_directions",
          "evidence",
          "extra_blocks"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "enum": [
              "error",
              "note",
              "out_of_scope"
            ]
          },
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "heading": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": [
              "string",
              "null"
            ]
          },
          "why_bad": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "fix_directions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/evidence"
            }
          },
          "extra_blocks": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/extra_block"
            }
          }
        },
        "additionalProperties": false
    },
    "section": {
      "type": "object",
      "required": [
        "title",
        "blocks"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "blocks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
